<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit — Promaster Floors</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lato:ital,wght@0,100;0,300;0,400;0,700;0,900;1,100;1,300;1,400;1,700;1,900&family=Open+Sans:wght@300;400;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/styles.css" />
    <style>
      .edit-bar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 9999;
        background: #111;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.6rem 2rem;
        font-family: 'Lato', sans-serif;
      }
      .edit-bar-title {
        font-weight: 700;
        font-size: 0.9rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.6);
      }
      .edit-bar-actions {
        display: flex;
        gap: 0.75rem;
        align-items: center;
      }
      .edit-btn {
        padding: 0.5rem 1.2rem;
        font-size: 0.85rem;
        font-weight: 700;
        border-radius: 0;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
      }
      .edit-btn-primary {
        background: #6B2FA0;
        color: #fff;
        border: none;
      }
      .edit-btn-primary:hover {
        background: #4F1F7A;
      }
      .edit-btn-outline {
        background: transparent;
        color: #fff;
        border: 1px solid rgba(255,255,255,0.3);
      }
      .edit-btn-outline:hover {
        border-color: #fff;
      }
      .edit-btn-saved {
        background: #1a7a3a;
      }
      .edit-bar-status {
        font-size: 0.8rem;
        color: rgba(255,255,255,0.5);
      }
      .edit-btn-lang {
        background: transparent;
        color: #fff;
        border: 1px solid rgba(255,255,255,0.3);
        padding: 0.5rem 1rem;
        font-size: 0.8rem;
        font-weight: 400;
        cursor: pointer;
      }
      .edit-btn-lang:hover {
        border-color: #fff;
      }
      .edit-btn-lang.active {
        background: #6B2FA0;
        border-color: #6B2FA0;
        font-weight: 700;
      }
      .lang-indicator {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.8rem;
        color: rgba(255,255,255,0.5);
        padding: 0.3rem 0.6rem;
        border: 1px solid rgba(255,255,255,0.2);
      }
      .lang-indicator .dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        display: inline-block;
      }
      .lang-indicator .dot.en { background: #4caf50; }
      .lang-indicator .dot.es { background: #ff9800; }
      [contenteditable="true"] {
        cursor: text;
        outline: none;
        transition: box-shadow 0.15s ease;
      }
      [contenteditable="true"]:hover {
        box-shadow: 0 0 0 2px rgba(107, 47, 160, 0.3);
      }
      [contenteditable="true"]:focus {
        box-shadow: 0 0 0 2px rgba(107, 47, 160, 0.6);
        background: rgba(255,255,255,0.4);
      }
      [contenteditable="true"].editing-es {
        box-shadow: 0 0 0 2px rgba(255, 152, 0, 0.4);
      }
      [contenteditable="true"].editing-es:focus {
        box-shadow: 0 0 0 2px rgba(255, 152, 0, 0.7);
        background: rgba(255, 243, 224, 0.4);
      }
      .edit-header-push {
        padding-top: 52px;
      }
      .edit-header-push .site-header {
        top: 52px;
      }
      @media (max-width: 760px) {
        .edit-bar {
          padding: 0.5rem 1rem;
          flex-wrap: wrap;
          gap: 0.5rem;
        }
        .edit-header-push {
          padding-top: 80px;
        }
        .edit-header-push .site-header {
          top: 80px;
        }
      }

      .img-replace-input {
        display: none;
      }
      .has-replace-btn {
        cursor: pointer;
      }
      .img-overlay {
        position: absolute;
        inset: 0;
        z-index: 50;
        background: rgba(255,255,255,0);
        transition: background 0.25s ease;
        pointer-events: none;
      }
      .has-replace-btn:hover .img-overlay {
        background: rgba(255,255,255,0.25);
      }
      .gallery-add-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.3rem 0.8rem;
        border: 1px dashed rgba(107,47,160,0.4);
        background: rgba(107,47,160,0.06);
        color: #6B2FA0;
        font-size: 0.8rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.2s ease;
        font-family: 'Lato', sans-serif;
        border-radius: 0;
        flex-shrink: 0;
      }
      .gallery-add-btn:hover {
        background: rgba(107,47,160,0.12);
        border-color: #6B2FA0;
      }
      .gallery-remove-btn {
        position: absolute;
        top: 6px;
        right: 6px;
        z-index: 60;
        width: 28px;
        height: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0,0,0,0.5);
        color: #fff;
        border: none;
        font-size: 1.1rem;
        cursor: pointer;
        opacity: 0;
        transition: opacity 0.2s ease;
        border-radius: 50%;
        line-height: 1;
        font-family: 'Lato', sans-serif;
        padding: 0;
      }
      .gallery-remove-btn:hover {
        background: rgba(180,0,0,0.8);
      }
      .has-replace-btn:hover .gallery-remove-btn {
        opacity: 1;
      }
    </style>
  </head>
  <body class="edit-header-push">
    <div class="edit-bar">
