    <script>
      var ALL_CONTENT = <%- JSON.stringify(content) %>;
      var edits = { en: {}, es: {} };
      var dirtyEn = {};
      var dirtyEs = {};
      for (var key in ALL_CONTENT) {
        edits.en[key] = ALL_CONTENT[key].en || "";
        edits.es[key] = ALL_CONTENT[key].es || "";
      }
      var activeLang = "en";

      var translateTimers = {};
      var langAtEdit = {};

      var els = document.querySelectorAll("[data-eid]");
      var eidToEl = {};
      for (var i = 0; i < els.length; i++) {
        var el = els[i];
        var eid = el.getAttribute("data-eid");
        eidToEl[eid] = el;
        el.addEventListener("input", function(e) {
          var eid = this.getAttribute("data-eid");
          edits[activeLang][eid] = this.innerHTML;
          if (activeLang === "en") {
            dirtyEn[eid] = true;
          } else {
            dirtyEs[eid] = true;
          }
          langAtEdit[eid] = activeLang;
          if (translateTimers[eid]) clearTimeout(translateTimers[eid]);
          translateTimers[eid] = setTimeout(function() {
            var sourceLang = langAtEdit[eid];
            if (sourceLang !== activeLang) return;
            var targetLang = sourceLang === "en" ? "es" : "en";
            var text = edits[sourceLang][eid];
            if (!text || !text.trim()) return;
            fetch("/api/translate", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ text: text, to: targetLang }),
            })
              .then(function (r) { return r.json(); })
              .then(function (data) {
                if (data.translation) {
                  edits[targetLang][eid] = data.translation;
                  setStatus("Auto Translated!");
                  setTimeout(function () { setStatus(""); }, 2000);
                }
              })
              .catch(function () {});
          }, 800);
        });
      }

      function applyLang(lang) {
        activeLang = lang;
        var isES = lang === "es";
        for (var eid in edits[lang]) {
          if (eidToEl[eid]) {
            eidToEl[eid].innerHTML = edits[lang][eid];
          }
        }
        for (var j = 0; j < els.length; j++) {
          els[j].classList.toggle("editing-es", isES);
        }
        document.getElementById("lang-display").textContent = isES ? "Editing: Spanish" : "Editing: English";
        document.getElementById("lang-dot").className = "dot " + lang;
        document.getElementById("lang-en-btn").classList.toggle("active", !isES);
        document.getElementById("lang-es-btn").classList.toggle("active", isES);
      }

      document.getElementById("lang-en-btn").addEventListener("click", function() { applyLang("en"); });
      document.getElementById("lang-es-btn").addEventListener("click", function() { applyLang("es"); });

      var saveBtn = document.getElementById("save-btn");
      var statusEl = document.getElementById("edit-status");
      var pending = false;

      function setStatus(msg, isError) {
        statusEl.textContent = msg;
        statusEl.style.color = isError ? "#ff6b6b" : "rgba(255,255,255,0.5)";
      }

      function updateEditsFromTranslations(translations) {
        for (var key in translations) {
          if (translations[key].es) {
            edits.es[key] = translations[key].es;
          }
          if (translations[key].en) {
            edits.en[key] = translations[key].en;
          }
        }
      }

      document.getElementById("restore-btn").addEventListener("click", function () {
        if (confirm("Discard all unsaved changes and revert to last save?")) {
          location.reload();
        }
      });

      saveBtn.addEventListener("click", function () {
        if (pending) return;
        pending = true;
        saveBtn.textContent = "Saving...";
        saveBtn.disabled = true;
        setStatus("");

        fetch("/api/save", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ en: edits.en, es: edits.es, dirtyEn: dirtyEn, dirtyEs: dirtyEs }),
        })
          .then(function (r) {
            if (!r.ok) throw new Error("Server error");
            return r.json();
          })
          .then(function (data) {
            if (data.success) {
              updateEditsFromTranslations(data.translations || {});
              dirtyEn = {};
              dirtyEs = {};
              setStatus("Saved!");
              saveBtn.textContent = "Saved";
              saveBtn.classList.add("edit-btn-saved");
              setTimeout(function () {
                saveBtn.textContent = "Save Changes";
                saveBtn.classList.remove("edit-btn-saved");
                setStatus("");
              }, 2000);
            } else {
              throw new Error(data.error || "Unknown error");
            }
          })
          .catch(function (err) {
            setStatus("Error: " + err.message, true);
            saveBtn.textContent = "Save Changes";
          })
          .finally(function () {
            pending = false;
            saveBtn.disabled = false;
          });
      });

      document.getElementById("restore-btn").addEventListener("click", function () {
        if (confirm("Discard all unsaved changes and revert to last save?")) {
          location.reload();
        }
      });

      (function() {
        var header = document.getElementById("site-header");
        var ticking = false;
        window.addEventListener("scroll", function() {
          if (!ticking) {
            window.requestAnimationFrame(function() {
              if (window.scrollY > 50) {
                header.classList.add("scrolled");
              } else {
                header.classList.remove("scrolled");
              }
              ticking = false;
            });
            ticking = true;
          }
        });
      })();

      (function() {
        var hamburger = document.getElementById("hamburger");
        var nav = document.querySelector(".site-header__nav");
        if (hamburger && nav) {
          hamburger.addEventListener("click", function() {
            hamburger.classList.toggle("open");
            nav.classList.toggle("open");
          });
          nav.querySelectorAll("a").forEach(function(link) {
            link.addEventListener("click", function() {
              hamburger.classList.remove("open");
              nav.classList.remove("open");
            });
          });
        }
      })();

      document.addEventListener("keydown", function (e) {
        if ((e.ctrlKey || e.metaKey) && e.key === "s") {
          e.preventDefault();
          saveBtn.click();
        }
      });

      function setupImageReplace(container, updateFn) {
        container.classList.add("has-replace-btn");
        if (getComputedStyle(container).position === "static") {
          container.style.position = "relative";
        }

        var input = document.createElement("input");
        input.type = "file";
        input.accept = "image/*";
        input.className = "img-replace-input";

        var overlay = document.createElement("div");
        overlay.className = "img-overlay";

        container.appendChild(overlay);
        container.appendChild(input);

        container.addEventListener("click", function (e) {
          if (e.target === input) return;
          input.click();
        });

        input.addEventListener("change", function () {
          var file = input.files[0];
          if (!file) return;

          setStatus("Uploading...");
          var fd = new FormData();
          fd.append("image", file);

          fetch("/api/upload-image", { method: "POST", body: fd })
            .then(function (r) {
              if (!r.ok) throw new Error("Upload failed");
              return r.json();
            })
            .then(function (data) {
              if (data.url) {
                updateFn(data.url);
                setStatus("Image updated!");
                setTimeout(function () { setStatus(""); }, 2000);
              }
            })
            .catch(function (err) {
              setStatus("Upload error: " + err.message, true);
            });
        });
      }

      var bgContainers = document.querySelectorAll(
        ".hero__bg, .work-card__image, .blog-card__image"
      );
      for (var i = 0; i < bgContainers.length; i++) {
        setupImageReplace(bgContainers[i], function (url) {
          this.style.backgroundImage = "url('" + url + "')";
        }.bind(bgContainers[i]));
      }

      function setupGalleryRemove(item, img) {
        var rmBtn = document.createElement("button");
        rmBtn.className = "gallery-remove-btn";
        rmBtn.innerHTML = "&times;";
        item.appendChild(rmBtn);

        rmBtn.addEventListener("click", function (e) {
          e.stopPropagation();
          if (!confirm("Remove this image?")) return;
          var src = img.getAttribute("src");
          var filename = src.split("/").pop();
          fetch("/api/gallery?filename=" + encodeURIComponent(filename), {
            method: "DELETE",
          })
            .then(function (r) {
              if (!r.ok) throw new Error("Delete failed");
              return r.json();
            })
            .then(function (data) {
              if (data.success) {
                item.remove();
                setStatus("Image removed!");
                setTimeout(function () { setStatus(""); }, 2000);
              }
            })
            .catch(function (err) {
              setStatus("Delete error: " + err.message, true);
            });
        });
      }

      var galleryItems = document.querySelectorAll(".gallery-strip-item");
      for (var i = 0; i < galleryItems.length; i++) {
        (function (item) {
          var img = item.querySelector("img");
          if (!img) return;
          setupImageReplace(item, function (url) {
            img.src = url;
          });
          setupGalleryRemove(item, img);
        })(galleryItems[i]);
      }

      var addButtons = document.querySelectorAll(".gallery-add-btn");
      for (var i = 0; i < addButtons.length; i++) {
        (function (btn) {
          var input = document.createElement("input");
          input.type = "file";
          input.accept = "image/*";
          input.className = "img-replace-input";
          btn.appendChild(input);

          btn.addEventListener("click", function (e) {
            if (e.target === input) return;
            input.click();
          });

          input.addEventListener("change", function () {
            var file = input.files[0];
            if (!file) return;

            setStatus("Uploading...");
            var fd = new FormData();
            fd.append("image", file);

            fetch("/api/upload-gallery", { method: "POST", body: fd })
              .then(function (r) {
                if (!r.ok) throw new Error("Upload failed");
                return r.json();
              })
              .then(function (data) {
                if (data.url) {
                  var strip = btn.closest(".gallery-category").querySelector(".gallery-strip");
                  var item = document.createElement("div");
                  item.className = "gallery-strip-item";
                  var img = document.createElement("img");
                  img.src = data.url;
                  img.alt = "Gallery image";
                  item.appendChild(img);
                  strip.insertBefore(item, strip.firstChild);
                  setupImageReplace(item, function (url) {
                    img.src = url;
                  });
                  setupGalleryRemove(item, img);
                  setStatus("Image added!");
                  setTimeout(function () { setStatus(""); }, 2000);
                }
              })
              .catch(function (err) {
                setStatus("Upload error: " + err.message, true);
              });
          });
        })(addButtons[i]);
      }
    </script>
  </body>
</html>
