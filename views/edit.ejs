    <script>
      (function () {
        var saveBtn = document.getElementById("save-btn");
        var statusEl = document.getElementById("edit-status");
        var pending = false;

        function collectEdits() {
          var els = document.querySelectorAll("[data-eid]");
          var edits = {};
          for (var i = 0; i < els.length; i++) {
            var el = els[i];
            var id = el.getAttribute("data-eid");
            edits[id] = el.innerHTML;
          }
          return edits;
        }

        function setStatus(msg, isError) {
          statusEl.textContent = msg;
          statusEl.style.color = isError ? "#ff6b6b" : "rgba(255,255,255,0.5)";
        }

        saveBtn.addEventListener("click", function () {
          if (pending) return;
          pending = true;
          saveBtn.textContent = "Saving...";
          saveBtn.disabled = true;
          setStatus("");

          var edits = collectEdits();

          fetch("/api/save", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ edits: edits }),
          })
            .then(function (r) {
              if (!r.ok) throw new Error("Server error");
              return r.json();
            })
            .then(function (data) {
              if (data.success) {
                setStatus("Saved!");
                saveBtn.textContent = "Saved";
                saveBtn.classList.add("edit-btn-saved");
                setTimeout(function () {
                  saveBtn.textContent = "Save Changes";
                  saveBtn.classList.remove("edit-btn-saved");
                  setStatus("");
                }, 2000);
              } else {
                throw new Error(data.error || "Unknown error");
              }
            })
            .catch(function (err) {
              setStatus("Error: " + err.message, true);
              saveBtn.textContent = "Save Changes";
            })
            .finally(function () {
              pending = false;
              saveBtn.disabled = false;
            });
        });

        document.addEventListener("keydown", function (e) {
          if ((e.ctrlKey || e.metaKey) && e.key === "s") {
            e.preventDefault();
            saveBtn.click();
          }
        });
      })();
    </script>
