    <link href="https://fonts.googleapis.com/css2?family=Lato:ital,wght@0,100;0,300;0,400;0,700;0,900;1,100;1,300;1,400;1,700;1,900&family=Open+Sans:wght@300;400;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/styles.css" />
    <style>
      .edit-bar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 9999;
        background: #111;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.6rem 2rem;
        font-family: 'Lato', sans-serif;
      }
      .edit-bar-title {
        font-weight: 700;
        font-size: 0.9rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.6);
      }
      .edit-bar-actions {
        display: flex;
        gap: 0.75rem;
        align-items: center;
      }
      .edit-btn {
        padding: 0.5rem 1.2rem;
        font-size: 0.85rem;
        font-weight: 700;
        border-radius: 0;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
      }
      .edit-btn-primary {
        background: #cc092f;
        color: #fff;
        border: none;
      }
      .edit-btn-primary:hover {
        background: #a80726;
      }
      .edit-btn-outline {
        background: transparent;
        color: #fff;
        border: 1px solid rgba(255,255,255,0.3);
      }
      .edit-btn-outline:hover {
        border-color: #fff;
      }
      .edit-btn-saved {
        background: #1a7a3a;
      }
      .edit-bar-status {
        font-size: 0.8rem;
        color: rgba(255,255,255,0.5);
      }
      [contenteditable="true"] {
        cursor: text;
        outline: none;
        transition: box-shadow 0.15s ease;
      }
      [contenteditable="true"]:hover {
        box-shadow: 0 0 0 2px rgba(204, 9, 47, 0.3);
      }
      [contenteditable="true"]:focus {
        box-shadow: 0 0 0 2px rgba(204, 9, 47, 0.6);
        background: rgba(255,255,255,0.4);
      }
      .edit-header-push {
        padding-top: 52px;
      }
      .edit-header-push .site-header {
        top: 52px;
      }
      @media (max-width: 760px) {
        .edit-bar {
          padding: 0.5rem 1rem;
          flex-wrap: wrap;
          gap: 0.5rem;
        }
        .edit-header-push {
          padding-top: 80px;
        }
        .edit-header-push .site-header {
          top: 80px;
        }
      }
    </style>
