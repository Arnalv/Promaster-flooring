          <span id="lang-display">Editing: English</span>
        </span>
        <button class="edit-btn-lang active" id="lang-en-btn">EN</button>
        <button class="edit-btn-lang" id="lang-es-btn">ES</button>
        <span class="edit-bar-status" id="edit-status"></span>
        <a href="/" class="edit-btn edit-btn-outline">View Site</a>
        <button class="edit-btn edit-btn-outline" id="restore-btn">Revert to Last Save</button>
        <button class="edit-btn edit-btn-primary" id="save-btn">Save Changes</button>
